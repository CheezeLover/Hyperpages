{
    order authenticate before respond
    order authorize before basicauth
    order replace after reverse_proxy

    security {
        local identity store localdb {
            realm local
            path /data/users.json
        }

        authentication portal myportal {
            crypto default token lifetime 86400
            crypto key sign-verify {env.AUTH_CRYPTO_KEY}
            enable identity store localdb
            cookie domain .{$HYPERSET_DOMAIN}
            cookie samesite lax
            cookie insecure off

            # --- SWAP THIS BLOCK WHEN CHANGING PROVIDERS ---
            transform user {
                match realm local
                match role authp/admin
                action add role hyperset/admin
            }
            transform user {
                match realm local
                match role authp/user
                action add role hyperset/user
            }
            # --- END SWAP BLOCK ---

            ui {
                links {
                    "Portal" https://{$HYPERSET_DOMAIN}
                    "Pages" https://pages.{$HYPERSET_DOMAIN}
                }
            }
        }

        authorization policy mypolicy {
            set auth url https://auth.{$HYPERSET_DOMAIN}/
            set token sources cookie header
            validate bearer header
            crypto key sign-verify {env.AUTH_CRYPTO_KEY}
            allow roles hyperset/admin hyperset/user
            inject headers with claims
        }
    }
}

auth.{$HYPERSET_DOMAIN} {
    tls internal {
        on_demand
    }
    authenticate with myportal
}

# ── Main portal (Next.js) ──────────────────────────────────────
{$HYPERSET_DOMAIN} {
    tls internal {
        on_demand
    }

    # Theme and branding assets — no auth needed
    handle /theme.json {
        root * /Caddy
        file_server
        header Content-Type "application/json"
        header Cache-Control "no-cache"
        header Access-Control-Allow-Origin "*"
    }

    handle /logos/* {
        root * /Caddy
        file_server
        header Cache-Control "public, max-age=86400"
        header Access-Control-Allow-Origin "*"
    }

    # Next.js static assets — no auth needed (required for /join page to hydrate)
    handle /_next/static/* {
        reverse_proxy hyperset-portal:3000 {
            flush_interval -1
        }
    }

    # Guest invite code entry page — no SSO needed
    handle /join {
        reverse_proxy hyperset-portal:3000 {
            flush_interval -1
        }
    }

    # Guest invite code redemption — no SSO needed
    # Portal validates the code and sets the access_token cookie itself.
    handle /join/* {
        reverse_proxy hyperset-portal:3000 {
            flush_interval -1
        }
    }

    # All other routes require SSO
    handle {
        authorize with mypolicy

        reverse_proxy hyperset-portal:3000 {
            # Explicitly strip any client-supplied auth headers first so they
            # can never reach the portal, then re-set them from the values that
            # caddy-security's inject-headers-with-claims placed in r.Header
            # after validating the JWT.  The strip-then-set pattern is safe
            # regardless of whether caddy-security uses Set or Add semantics.
            header_up -X-Token-User-Id
            header_up -X-Token-User-Email
            header_up -X-Token-User-Roles
            header_up X-Token-User-Id    {http.request.header.X-Token-User-Id}
            header_up X-Token-User-Email {http.request.header.X-Token-User-Email}
            header_up X-Token-User-Roles {http.request.header.X-Token-User-Roles}
            flush_interval -1
        }
    }

    header Strict-Transport-Security "max-age=31536000; includeSubDomains"
}

# ── Pages service ──────────────────────────────────────────────
pages.{$HYPERSET_DOMAIN} {
    tls internal {
        on_demand
    }
    authorize with mypolicy

    # Theme and branding assets
    handle /theme.json {
        root * /Caddy
        file_server
        header Content-Type "application/json"
        header Cache-Control "no-cache"
        header Access-Control-Allow-Origin "*"
    }
    
    handle /logos/* {
        root * /Caddy
        file_server
        header Cache-Control "public, max-age=86400"
        header Access-Control-Allow-Origin "*"
    }

    reverse_proxy hyperset-pages:8000 {
        header_down -X-Frame-Options
        header_down -Content-Security-Policy
    }
    
    header Content-Security-Policy "frame-ancestors 'self' https://{$HYPERSET_DOMAIN}"
    header Strict-Transport-Security "max-age=31536000; includeSubDomains"
}

