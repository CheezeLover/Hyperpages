# SECURITY REQUIREMENTS - READ BEFORE DEPLOYING
#
# ⚠️  CRITICAL: You MUST change all secrets below before deploying!
#    Run: openssl rand -hex 32  to generate secure values.
#
# 🔐 Minimum Security Requirements:
#    - All secrets must be 32+ characters
#    - Use only cryptographically secure random values
#    - Never commit .env with real secrets to git

# Domain — change this one line to switch domains, then restart gateway
HYPERSET_DOMAIN=hyperset.internal

# ═══════════════════════════════════════════════════════════════
# 🔐 SECURITY: SECRET KEYS - MUST BE CHANGED!
# ═══════════════════════════════════════════════════════════════

# Database password for the portal PostgreSQL instance
# Generate with: openssl rand -hex 32
PORTAL_DATABASE_PASSWORD=CHANGE_ME_RUN_openssl_rand_hex_32

# Auth crypto key for JWT tokens (min 32 chars hex)
# Generate with: openssl rand -hex 32
AUTH_CRYPTO_KEY=CHANGE_ME_run_openssl_rand_hex_32_and_paste_result_here_min_32_chars

# ═══════════════════════════════════════════════════════════════
# 🔓 OAuth Configuration (Optional - only for external providers)
# ═══════════════════════════════════════════════════════════════

OAUTH_CLIENT_ID=placeholder
OAUTH_CLIENT_SECRET=placeholder
ENTRA_TENANT_ID=common
OIDC_METADATA_URL=https://localhost/.well-known/openid-configuration
